<style>
  .navbar-brand {
  font-weight: 700;
  color: #fe424d;
  font-size: 1.3rem;
}
  .search-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0 1rem;
    white-space: nowrap;
  }
  .search-btn:hover {
    background-color: #d63031;
    color: #fff;
  }
  .search-btn i {
    margin-right: 0.5rem;
  }
  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    font-size: 1rem;
    min-width: 0;
    border: 1.5px solid #ddd;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }

  /* ✅ Fix: Give collapsed navbar a solid white background */
  .navbar-collapse {
    background-color: #fff;
    z-index: 1000;
    padding: 0.5rem 1rem;
  }

  @media (max-width: 767px) {
    .search-form {
      width: 100%;
      margin: 0.5rem 0;
    }
    .search-inp {
      width: 100%;
    }
    /* ✅ Fix: Add shadow and border so it looks clean when open */
    .navbar-collapse.show {
      border-top: 1px solid #eee;
      box-shadow: 0 4px 8px rgba(0,0,0,0.08);
      padding-bottom: 1rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-white border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i> Wanderlust
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left links -->
      <div class="navbar-nav me-3">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- Search bar -->
      <form class="d-flex flex-grow-1 me-3 search-form" role="search">
        <input class="form-control me-2 search-inp" type="search" placeholder="Search destinations" />
        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <!-- Right links -->
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Airbnb your home</a>
        <% if(!currUser){ %>
          <a class="nav-link" href="/signup"><b>Sign up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>
        <% if(currUser){ %>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <% } %>
      </div>

    </div>
  </div>
</nav>